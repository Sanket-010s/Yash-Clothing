# Next.js Public Environment Variables
# Note: NEXT_PUBLIC_ variables are exposed to the browser

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Razorpay Payment Gateway (Public Key Only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_public_key_id

# Application Settings
NEXT_PUBLIC_APP_NAME=Your Store Name
NEXT_PUBLIC_APP_DESCRIPTION=Your store description

# Analytics (if using)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
